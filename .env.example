# Google Maps JavaScript API key (untuk fitur Pilih Lokasi di Peta - Outlet)
# Dapatkan key di: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=

# Backend API URL
VITE_API_URL=https://api.pinangmajusejahtera.my.id

# Environment
VITE_NODE_ENV=development
